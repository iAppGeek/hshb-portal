# Copy to .env.local
#
# Google Analytics
NEXT_PUBLIC_GA_ID=
#
# NextAuth
AUTH_SECRET=
# Base URL of this app, e.g. http://localhost:3000 or https://portal.hshb.org.uk
AUTH_URL=
#
# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_SECRET=
#
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
#
# Web Push (VAPID) — npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
